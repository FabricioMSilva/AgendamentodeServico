# .env.local.example
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Found in Supabase Dashboard → Project Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your-jwt-secret
# Correios API token for CEP lookup (official API used by the address form)
CORREIOS_API_TOKEN=your-correios-api-token
# Comma-separated consultant emails — NEVER add NEXT_PUBLIC_ prefix
SUPER_ADMIN_EMAILS=consultant@yourcompany.com,another@example.com

# Internal automation/webhook secrets. Use long random values.
CRON_SECRET=change-this-cron-secret
WHATSAPP_WEBHOOK_SECRET=change-this-webhook-secret

# WhatsApp provider. Start with Evolution API for a free/self-hosted MVP.
WHATSAPP_PROVIDER=evolution
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE=your-instance-name
