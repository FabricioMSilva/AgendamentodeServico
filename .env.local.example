# .env.local.example
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Encontrado no painel do Supabase em Project Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your-jwt-secret
# Token da API dos Correios para busca de CEP (API oficial usada pelo formulario de endereco)
CORREIOS_API_TOKEN=your-correios-api-token
# Emails dos consultores separados por virgula — NUNCA adicione o prefixo NEXT_PUBLIC_
SUPER_ADMIN_EMAILS=consultant@yourcompany.com,another@example.com

# Segredos internos de automacao/webhook. Use valores longos e aleatorios.
CRON_SECRET=change-this-cron-secret
WHATSAPP_WEBHOOK_SECRET=change-this-webhook-secret

# Provedor de WhatsApp. Comece com Evolution API para um MVP gratis/hospedado por conta propria.
WHATSAPP_PROVIDER=evolution
EVOLUTION_API_URL=http://localhost:8080
# Deve ser igual a AUTHENTICATION_API_KEY ao usar docker-compose.evolution.yml localmente.
EVOLUTION_API_KEY=your-evolution-api-key
# Padrao local usado nos exemplos do README: ibeleza-local
EVOLUTION_INSTANCE=your-instance-name
