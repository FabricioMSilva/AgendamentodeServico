# .env.local.example
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Encontrado no painel do Supabase em Project Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your-jwt-secret
# Token da API dos Correios para busca de CEP (API oficial usada pelo formulario de endereco)
CORREIOS_API_TOKEN=your-correios-api-token
# Emails dos consultores separados por virgula — NUNCA adicione o prefixo NEXT_PUBLIC_
SUPER_ADMIN_EMAILS=consultant@yourcompany.com,another@example.com

# Segredos internos de automacao/webhook. Use valores longos e aleatorios.
CRON_SECRET=change-this-cron-secret
WHATSAPP_WEBHOOK_SECRET=change-this-webhook-secret

# Provedor de WhatsApp. Twilio e o caminho padrao agora.
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Use o sandbox ou um numero aprovado no formato whatsapp:+55...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Provedor de SMS opcional para recuperacao de senha temporaria.
# O WhatsApp usa as variaveis TWILIO_* acima.
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_PHONE=+15551234567
